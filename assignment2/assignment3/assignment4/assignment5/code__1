class Library:
    def __init__(self):
        self.books = []
        self.users = []  # Student va Teacher larni saqlash uchun

    def add_book(self, book):
        self.books.append(book)
        print(f"Kitob qo'shildi: {book.get_title()}")

    def add_user(self, user):
        self.users.append(user)
        print(f"Foydalanuvchi qo'shildi: {user.get_fullname()}")

    def show_available_books(self):
        print("\nMavjud kitoblar:")
        for book in self.books:
            if book.is_available():
                print(f" - {book.get_title()} ({book.get_author()})")

    def show_all_users(self):
        print("\nBarcha foydalanuvchilar:")
        for user in self.users:
            print(f" - {user.get_fullname()}")


