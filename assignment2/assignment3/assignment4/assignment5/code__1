class Book:
    def __init__(self, title, author):
        self.title = title
        self.author = author
        self.available = True

    def get_title(self):
        return self.title

    def get_author(self):
        return self.author

    def get_info(self):
        return f"Kitob: {self.title} | Muallif: {self.author} | Holati: {'Mavjud' if self.available else 'Olingan'}"

    def is_available(self):
        return self.available


class Student:
    def __init__(self, fullname):
        self.fullname = fullname
        self.borrowed_books = []

    def get_fullname(self):
        return self.fullname

    def borrow_book(self, book):
        if book.is_available():
            book.available = False
            self.borrowed_books.append(book)
            print(f"{self.fullname} kitobni oldi: {book.get_title()}")
        else:
            print(f"Kechirasiz, '{book.get_title()}' kitobi hozirda mavjud emas.")

    def return_book(self, book):
        if book in self.borrowed_books:
            book.available = True
            self.borrowed_books.remove(book)
            print(f"{self.fullname} kitobni qaytardi: {book.get_title()}")
        else:
            print("Bu kitob sizda emas.")

    def get_borrowed_books(self):
        return [book.get_title() for book in self.borrowed_books]


