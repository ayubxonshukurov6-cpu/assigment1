# 4. Foydalanuvchidan 4 ta raqam so'rang va ularni kortejga joylashtirib, chop eting.
raqamlar = tuple(int(input(f"{i+1}-raqam: ")) for i in range(4))
print(raqamlar)

# 5. Kortej ichidagi elementlarni for tsikli yordamida chop eting.
for x in raqamlar:
    print(x)

# 6. Kortejning uzunligini aniqlang va chop eting.
print("Uzunligi:", len(raqamlar))

# 7. Kortejdagi oxirgi elementni chop eting.
print("Oxirgi element:", raqamlar[-1])

# 8. Ikkita kortejni birlashtirib, yangi kortej yaratib va uni chop eting.
k1 = (1, 2, 3)
k2 = (4, 5, 6)
print(k1 + k2)

# 9. Kortejdagi eng katta va eng kichik elementni chop eting.
print("Eng katta:", max(raqamlar))
print("Eng kichik:", min(raqamlar))

# 10. Kortejda bitta element mavjudligini tekshiring va natijani chop eting.
print(20 in raqamlar)

# 11. Kortejdan kesma (slice) olib, faqat ma'lum bir qismni chop eting.
print("Kesma [1:3]:", raqamlar[1:3])

# 12. Kortejdagi barcha raqamlarni yig'indisini toping va chop eting.
print("Yig'indi:", sum(raqamlar))

# 13. Kortejni alifbo tartibida chop eting (agar stringlar bo'lsa).
harflar = ('b', 'a', 'c', 'd')
print(sorted(harflar))

# 14. Kortejdagi qiymatlar sonini sanang (masalan, nechta marta "apple" borligini tekshiring).
mevalar = ("apple", "banana", "apple", "cherry")
print("apple soni:", mevalar.count("apple"))

# 15. Kortejdagi raqamlarni teskari tartibda chop eting.
print("Teskari:", raqamlar[::-1])